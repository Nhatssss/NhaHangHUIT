<Window x:Class="Nha_Hang_Huit.Views.MainView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nha Hang HUIT - Phan mem quan ly"
        WindowState="Maximized" WindowStartupLocation="CenterScreen">
    <Window.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#E8F5E9" Offset="0"/>
            <GradientStop Color="#F1F8E9" Offset="1"/>
        </LinearGradientBrush>
    </Window.Background>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ====== TOOLBAR ====== -->
        <Border Grid.Row="0" Background="#2E7D32" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo / Title -->
                <TextBlock Grid.Column="0" Text="NHÀ HÀNG HUIT"
                           FontSize="22" FontWeight="Bold" Foreground="White"
                           VerticalAlignment="Center" Margin="0,0,30,0"/>

                <!-- Ca status / Admin badge -->
                <Border Grid.Column="1" Background="#1B5E20" CornerRadius="4" Padding="10,5" Margin="0,0,20,0">
                    <StackPanel Orientation="Vertical">
                        <TextBlock Text="{Binding TrangThaiCaText}"
                                   Foreground="#FFF9C4" FontWeight="Bold" FontSize="13"/>
                        <TextBlock Text="{Binding TenNhanVienText}"
                                   Foreground="#C8E6C9" FontSize="11"/>
                    </StackPanel>
                </Border>

                <!-- Quick stats -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding TongHoaDonText}" Foreground="White" FontSize="13" Margin="10,0"/>
                    <TextBlock Text=" | " Foreground="#A5D6A7" FontSize="13"/>
                    <TextBlock Text="Doanh thu: " Foreground="White" FontSize="13"/>
                    <TextBlock Text="{Binding DoanhThuText}" Foreground="#FFF9C4" FontWeight="Bold" FontSize="14"/>
                </StackPanel>

                <!-- Refresh button -->
                <StackPanel Grid.Column="3" Orientation="Horizontal">
                    <Button Content="🔄 Cập nhật" Height="32"
                            Command="{Binding RefreshCommand}"
                            Background="#43A047" Foreground="White" Margin="3,0"
                            BorderThickness="0" Padding="10,0" Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="4" Padding="10,4">
                                                <ContentPresenter HorizontalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ====== MAIN CONTENT ====== -->
        <Grid Grid.Row="1" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ======================== ADMIN SIDEBAR ======================== -->
            <Border Grid.Column="0" Background="White" CornerRadius="8" Margin="0,0,10,0"
                    Visibility="{Binding AdminPanelVisibility}">
                <StackPanel Margin="10">
                    <TextBlock Text="QUAN LY" FontSize="14" FontWeight="Bold"
                               Foreground="#00695C" Margin="0,5,0,15"/>

                    <Button Content="📊 BÁO CÁO DOANH THU" Height="40" Margin="0,0,0,5"
                            Command="{Binding MoBaoCaoCommand}"
                            Background="#00695C" Foreground="White" BorderThickness="0"
                            Cursor="Hand" Padding="10,0">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="5" Padding="10,5">
                                                <ContentPresenter HorizontalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Content="📈 TOP MÓN BÁN CHẠY" Height="40" Margin="0,0,0,5"
                            Command="{Binding MoTopMonCommand}"
                            Background="#004D40" Foreground="White" BorderThickness="0"
                            Cursor="Hand" Padding="10,0">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="5" Padding="10,5">
                                                <ContentPresenter HorizontalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Separator Margin="0,10"/>
                    <TextBlock Text="THONG TIN NHANH" FontSize="12" Foreground="#757575" Margin="0,0,0,5"/>

                    <Border Background="#E0F2F1" CornerRadius="5" Padding="8" Margin="0,0,0,5">
                        <StackPanel>
                            <TextBlock Text="{Binding TongHoaDonText}" FontSize="13"/>
                            <TextBlock Text="{Binding DoanhThuText}" FontSize="16" FontWeight="Bold" Foreground="#E65100"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- ======================== NHAN VIEN SIDEBAR ======================== -->
            <Border Grid.Column="0" Background="White" CornerRadius="8" Margin="0,0,10,0"
                    Visibility="{Binding NhanVienVisibility}">
                <StackPanel Margin="10">
                    <TextBlock Text="CHỨC NĂNG" FontSize="14" FontWeight="Bold"
                               Foreground="#2E7D32" Margin="0,5,0,15"/>

                    <!-- Mo / Dong Ca -->
                    <Button Content="🚀 MỞ CA" Height="40" Margin="0,0,0,5"
                            Command="{Binding MoCaCommand}"
                            Background="#2E7D32" Foreground="White" BorderThickness="0"
                            Cursor="Hand" Padding="10,0"
                            IsEnabled="{Binding CoTheMoCa}">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="5" Padding="10,5"
                                                    Opacity="{Binding IsEnabled, RelativeSource={RelativeSource Self}, Converter={x:Null}}">
                                                <ContentPresenter HorizontalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter Property="Opacity" Value="0.5"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Content="🔒 ĐÓNG CA" Height="40" Margin="0,0,0,10"
                            Command="{Binding DongCaCommand}"
                            Background="#C62828" Foreground="White" BorderThickness="0"
                            Cursor="Hand" Padding="10,0"
                            IsEnabled="{Binding CoTheDongCa}">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="5" Padding="10,5"
                                                    Opacity="{Binding IsEnabled, RelativeSource={RelativeSource Self}, Converter={x:Null}}">
                                                <ContentPresenter HorizontalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter Property="Opacity" Value="0.5"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Separator Margin="0,5"/>

                    <!-- Chuc nang chinh (chi enable khi da mo ca) -->
                    <Button Content="🗂 GỌI MÓN" Height="40" Margin="0,0,0,5"
                            Command="{Binding MoMenuCommand}"
                            Background="#1565C0" Foreground="White" BorderThickness="0"
                            Cursor="Hand" Padding="10,0"
                            IsEnabled="{Binding CoTheThaoTac}">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="5" Padding="10,5">
                                                <ContentPresenter HorizontalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter Property="Opacity" Value="0.5"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Content="💳 THANH TOÁN" Height="40" Margin="0,0,0,5"
                            Command="{Binding MoThanhToanCommand}"
                            Background="#E65100" Foreground="White" BorderThickness="0"
                            Cursor="Hand" Padding="10,0"
                            IsEnabled="{Binding CoTheThaoTac}">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="5" Padding="10,5">
                                                <ContentPresenter HorizontalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter Property="Opacity" Value="0.5"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Content="👥 KHÁCH HÀNG" Height="40" Margin="0,0,0,5"
                            Command="{Binding MoKhachHangCommand}"
                            Background="#6A1B9A" Foreground="White" BorderThickness="0"
                            Cursor="Hand" Padding="10,0"
                            IsEnabled="{Binding CoTheThaoTac}">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="5" Padding="10,5">
                                                <ContentPresenter HorizontalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter Property="Opacity" Value="0.5"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Content="📈 TOP MÓN BÁN CHẠY" Height="40" Margin="0,0,0,5"
                            Command="{Binding MoTopMonCommand}"
                            Background="#004D40" Foreground="White" BorderThickness="0"
                            Cursor="Hand" Padding="10,0"
                            IsEnabled="{Binding CoTheThaoTac}">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="5" Padding="10,5">
                                                <ContentPresenter HorizontalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter Property="Opacity" Value="0.5"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Separator Margin="0,5"/>

                    <Button Content="🗑 XÓA GIỎ HÀNG" Height="35"
                            Command="{Binding XoaGioHangCommand}"
                            Background="#757575" Foreground="White" BorderThickness="0"
                            Cursor="Hand" Padding="10,0"
                            IsEnabled="{Binding CoTheThaoTac}">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="5" Padding="10,5">
                                                <ContentPresenter HorizontalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter Property="Opacity" Value="0.5"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Border>

            <!-- ====== RIGHT CONTENT ====== -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Thong bao -->
                <Border Grid.Row="0" Background="#FFF9C4" CornerRadius="5" Padding="10" Margin="0,0,0,10">
                    <TextBlock Text="{Binding ThongBaoHienTai}" FontSize="13" Foreground="#F57F17"/>
                </Border>

                <!-- ====== ADMIN DASHBOARD ====== -->
                <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="20"
                        Visibility="{Binding AdminPanelVisibility}">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="BẢNG ĐIỀU KHIỂN QUẢN LÝ" FontSize="22" FontWeight="Bold"
                                   Foreground="#00695C" HorizontalAlignment="Center" Margin="0,0,0,30"/>

                        <Border Background="#E0F2F1" CornerRadius="10" Padding="30" Margin="0,0,0,20">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="250"/>
                                    <ColumnDefinition Width="250"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Row="0" Grid.Column="0" HorizontalAlignment="Center" Margin="10">
                                    <TextBlock Text="TỔNG HÓA ĐƠN" FontSize="14" Foreground="#757575" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding TongHoaDonText}" FontSize="24" FontWeight="Bold"
                                               Foreground="#00695C" HorizontalAlignment="Center"/>
                                </StackPanel>

                                <StackPanel Grid.Row="0" Grid.Column="1" HorizontalAlignment="Center" Margin="10">
                                    <TextBlock Text="DOANH THU" FontSize="14" Foreground="#757575" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding DoanhThuText}" FontSize="24" FontWeight="Bold"
                                               Foreground="#E65100" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <TextBlock Text="Chọn chức năng bên trái để xem báo cáo chi tiết."
                                   FontSize="14" Foreground="#757575" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- ====== NHAN VIEN DASHBOARD + CART ====== -->
                <Grid Grid.Row="1" Visibility="{Binding NhanVienVisibility}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Blocking overlay: chua mo ca -->
                    <Border Grid.Row="0" Grid.RowSpan="2" Background="#80FFFFFF"
                            Visibility="{Binding NoCaBlockedVisibility}" CornerRadius="8">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="⛔" FontSize="64" HorizontalAlignment="Center"/>
                            <TextBlock Text="CHƯA MỞ CA" FontSize="24" FontWeight="Bold"
                                       Foreground="#C62828" HorizontalAlignment="Center" Margin="0,10,0,5"/>
                            <TextBlock Text="Vui lòng nhấn nút MỞ CA bên trái để bắt đầu làm việc!"
                                       FontSize="14" Foreground="#757575" HorizontalAlignment="Center"/>
                            <TextBlock Text="Các chức năng sẽ được kích hoạt sau khi mở ca."
                                       FontSize="13" Foreground="#9E9E9E" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Cart header (chua hien neu chua mo ca) -->
                    <Border Grid.Row="0" Background="White" CornerRadius="5,5,0,0" Padding="10"
                            BorderBrush="#E0E0E0" BorderThickness="1"
                            Visibility="{Binding CaDaMoVisibility}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="GIỎ HÀNG HIỆN TẠI" FontSize="14" FontWeight="Bold" Foreground="#2E7D32"/>
                            <TextBlock Grid.Column="1" Text="{Binding KhachHangInfo}" Foreground="#1565C0" FontSize="13" Margin="10,0"/>
                            <TextBlock Grid.Column="2" Text="{Binding TongTienGioHangText}" FontWeight="Bold" Foreground="#E65100" FontSize="16"/>
                        </Grid>
                    </Border>

                    <!-- Cart items -->
                    <ListBox Grid.Row="1" ItemsSource="{Binding GioHangItems}"
                             Background="White" BorderThickness="1,0,1,1"
                             BorderBrush="#E0E0E0"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             Visibility="{Binding CaDaMoVisibility}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="5" BorderBrush="#F5F5F5" BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="120"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding TenMonAn}" FontSize="14"/>
                                        <TextBlock Grid.Column="1" Text="{Binding SoLuong, StringFormat='x {}{0}'}" FontSize="13" Foreground="#757575"/>
                                        <TextBlock Grid.Column="2" Text="{Binding ThanhTien, StringFormat='{}{0:N0} VND'}" FontSize="14" FontWeight="Bold" Foreground="#2E7D32" HorizontalAlignment="Right"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>
