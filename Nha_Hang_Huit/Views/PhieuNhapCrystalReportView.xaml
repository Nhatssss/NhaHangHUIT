<UserControl x:Class="Nha_Hang_Huit.Views.PhieuNhapCrystalReportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:wfi="clr-namespace:System.Windows.Forms.Integration;assembly=WindowsFormsIntegration"
             Background="White">
    <Grid>
        <wfi:WindowsFormsHost Name="winFormsHost">
            <wf:CrystalReportViewer x:Name="crystalReportViewer"
                                    xmlns:wf="clr-namespace:CrystalDecisions.Windows.Forms;assembly=CrystalDecisions.Windows.Forms"
                                    DisplayGroupTree="False"
                                    ShowPrintButton="True"
                                    ShowExportButton="True"
                                    ShowZoomButton="True"
                                    ToolPanelView="None" />
        </wfi:WindowsFormsHost>
    </Grid>
</UserControl>
