<Window x:Class="Nha_Hang_Huit.Views.PhieuNhapView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Phiếu nhập hàng - Nhà Hàng HUIT"
        WindowStartupLocation="CenterScreen"
        Width="1000" Height="650"
        FontFamily="Segoe UI"
        TextElement.Foreground="#333333"
        Background="#F5F5F5">
    <Window.Resources>
        <Style TargetType="Button" x:Key="FilterButton">
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="3,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="#EEEEEE"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
        </Style>
        <Style TargetType="Button" x:Key="ActiveFilterButton" BasedOn="{StaticResource FilterButton}">
            <Setter Property="Background" Value="#E64A19"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#E64A19"/>
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="RowDetailsVisibilityMode" Value="Collapsed"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
        </Style>
    </Window.Resources>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#2E7D32" Padding="10" CornerRadius="4" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Phiếu nhập hàng" FontSize="20"
                           FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>

                <!-- Filter buttons -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="20,0,0,0"
                            VerticalAlignment="Center">
                    <Button Content="Hôm nay" Command="{Binding FilterTodayCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource FilterButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding FilterToday}" Value="True">
                                        <Setter Property="Background" Value="#E64A19"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="BorderBrush" Value="#E64A19"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="Tuần này" Command="{Binding FilterWeekCommand}"
                            Padding="10,5" Margin="3,0" Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource FilterButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding FilterWeek}" Value="True">
                                        <Setter Property="Background" Value="#E64A19"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="BorderBrush" Value="#E64A19"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="Tháng này" Command="{Binding FilterMonthCommand}"
                            Padding="10,5" Margin="3,0" Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource FilterButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding FilterMonth}" Value="True">
                                        <Setter Property="Background" Value="#E64A19"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="BorderBrush" Value="#E64A19"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="Tất cả" Command="{Binding FilterAllCommand}"
                            Padding="10,5" Margin="3,0" Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource FilterButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding FilterAll}" Value="True">
                                        <Setter Property="Background" Value="#E64A19"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="BorderBrush" Value="#E64A19"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>

                <!-- Stats + Close -->
                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding TongPhieuText}" Foreground="#C8E6C9" FontSize="12" Margin="5,0" VerticalAlignment="Center"/>
                    <TextBlock Text="|" Foreground="#A5D6A7" FontSize="12" Margin="5,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Tổng chi:" Foreground="#C8E6C9" FontSize="12" Margin="5,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding TongChiPhiText}" Foreground="#FFF9C4" FontWeight="Bold" FontSize="13" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <Button Content="Làm mới" Command="{Binding RefreshCommand}"
                            Background="#43A047" Foreground="White" BorderThickness="0"
                            Padding="10,5" Margin="3,0" Cursor="Hand"/>
                    <Button Content="Đóng" Command="{Binding DongCommand}"
                            Background="#C62828" Foreground="White" BorderThickness="0"
                            Padding="10,5" Margin="3,0" Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: List of Purchase Orders -->
            <Border Grid.Column="0" Background="White" CornerRadius="4" BorderBrush="#DDDDDD" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#43A047" Padding="8" CornerRadius="4,4,0,0">
                        <TextBlock Text="Danh sách phiếu nhập" Foreground="White" FontWeight="Bold" FontSize="13"/>
                    </Border>

                    <DataGrid Grid.Row="1" ItemsSource="{Binding PhieuNhapList}"
                              SelectedItem="{Binding SelectedPhieuNhap, Mode=TwoWay}"
                              Margin="5">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Mã PN" Binding="{Binding MaPhieuNhap}" Width="50"/>
                            <DataGridTextColumn Header="Nhà cung cấp" Binding="{Binding TenNhaCungCap}" Width="*"/>
                            <DataGridTextColumn Header="Ngày nhập" Binding="{Binding NgayNhapDisplay}" Width="110"/>
                            <DataGridTextColumn Header="Người giao" Binding="{Binding NguoiGiao}" Width="100"/>
                            <DataGridTextColumn Header="Tổng tiền" Binding="{Binding TongTienDisplay}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- Separator -->
            <GridSplitter Grid.Column="1" Width="4" Margin="5,0" ResizeBehavior="PreviousAndNext"
                          Background="#DDDDDD" HorizontalAlignment="Stretch"/>

            <!-- Right: Detail -->
            <Border Grid.Column="2" Background="White" CornerRadius="4" BorderBrush="#DDDDDD" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Detail header -->
                    <Border Grid.Row="0" Background="#43A047" Padding="8" CornerRadius="4,4,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Chi tiết phiếu nhập" Foreground="White" FontWeight="Bold" FontSize="13"/>
                            <TextBlock Text="{Binding PhieuNhapInfoText, StringFormat=' - {0}'}" Foreground="#C8E6C9" FontSize="11" VerticalAlignment="Center" Margin="5,0,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Supplier info -->
                    <Border Grid.Row="1" Background="#FFF9C4" Padding="8" BorderBrush="#FFE082" BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{Binding SelectedPhieuNhap.TenNhaCungCap, StringFormat='NCC: {0}'}" FontWeight="Bold" FontSize="12"/>
                                <TextBlock Text="{Binding SelectedPhieuNhap.SoDienThoaiNCC, StringFormat='SĐT: {0}'}" FontSize="11" Foreground="#666666"/>
                                <TextBlock Text="{Binding SelectedPhieuNhap.NgayNhap, StringFormat='Ngày nhập: {0:dd/MM/yyyy HH:mm}'}" FontSize="11" Foreground="#666666"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="{Binding SelectedPhieuNhap.NguoiGiao, StringFormat='Người giao: {0}'}" FontSize="11" Foreground="#666666"/>
                                <TextBlock Text="{Binding SelectedPhieuNhap.NguoiNhan, StringFormat='Người nhận: {0}'}" FontSize="11" Foreground="#666666"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Materials table -->
                    <DataGrid Grid.Row="2" ItemsSource="{Binding ChiTietList}" Margin="5">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="#" Binding="{Binding MaChiTiet}" Width="40"/>
                            <DataGridTextColumn Header="Nguyên liệu" Binding="{Binding TenNguyenLieu}" Width="*"/>
                            <DataGridTextColumn Header="ĐVT" Binding="{Binding DonViTinh}" Width="50"/>
                            <DataGridTextColumn Header="SL" Binding="{Binding SoLuongDisplay}" Width="70"/>
                            <DataGridTextColumn Header="ĐG" Binding="{Binding DonGiaDisplay}" Width="80"/>
                            <DataGridTextColumn Header="Thành tiền" Binding="{Binding ThanhTienDisplay}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Totals -->
                    <Border Grid.Row="3" Background="#E8F5E9" Padding="10" BorderBrush="#C8E6C9" BorderThickness="0,1,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Tổng cộng:" FontWeight="Bold" FontSize="15" VerticalAlignment="Center"/>
                            <Button Grid.Column="1" Content="In phiếu" Command="{Binding InPhieuCommand}"
                                    Background="#00695C" Foreground="White" BorderThickness="0"
                                    Padding="12,5" Margin="5,0" Cursor="Hand" FontWeight="Bold">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}"
                                                            CornerRadius="4" Padding="8,4">
                                                        <ContentPresenter HorizontalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <TextBlock Grid.Column="2" Text="{Binding TongTienPhieuText}" FontWeight="Bold" FontSize="16" Foreground="#E64A19" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>